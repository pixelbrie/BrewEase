# logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# build output
dist/
build/
coverage/

# system/editor files
.DS_Store
Thumbs.db
.vscode/*
!.vscode/extensions.json
.idea/

# Docker/local overrides
docker-compose.override.yml

# optional: ignore local database/cache/temp files
*.log
*.tmp
