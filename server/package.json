{
  "name": "brewease-server",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "nodemon -L --watch src src/server.js",
    "start": "node src/server.js",
    "seed": "node src/scripts/seed.js",
    "teardown": "node src/scripts/teardown.js",
    "seed:docker": "docker compose run -T --rm --no-deps server node src/scripts/seed.js",
    "teardown:docker": "docker compose run -T --rm --no-deps server node src/scripts/teardown.js"
  },
  "dependencies": {
    "bcrypt": "6.0.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-session": "^1.17.3",
    "firebase-admin": "^12.0.0"
  },
  "devDependencies": {
    "nodemon": "^3.1.0"
  }
}
